{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "esModuleInterop": true,
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "moduleResolution": "bundler",
    "outDir": "lib",
    "rootDir": "src/components"
  },
  "include": ["src/components/*.ts", "src/env.d.ts"],
  "exclude": ["node_modules", "lib", "src/components/browser.ts"]
}
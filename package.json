{
  "name": "litos-ui",
  "version": "0.18.0",
  "description": "基于 Web Component 的 UI 组件库",
  "keywords": [
    "component library",
    "litos-ui",
    "ui framework",
    "web component"
  ],
  "homepage": "https://dvshu.github.io/litos-ui/",
  "bugs": {
    "url": "https://github.com/DvShu/litos-ui/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DvShu/litos-ui.git"
  },
  "files": [
    "lib",
    "styles"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "unpkg": "./lib/litos-ui.min.js",
  "jsdelivr": "./lib/litos-ui.min.js",
  "exports": {
    "./styles/*": "./styles/*",
    "./lib/*": "./lib/*",
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "docs:dev": "vitepress dev docs --force --host 0.0.0.0",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "create": "node scripts/index.js create",
    "dts:build": "tsc -p tsconfig.build.json && node scripts/dts.js",
    "lib:build": "pnpm build && pnpm dts:build"
  },
  "dependencies": {
    "alien-signals": "^3.1.2",
    "iconify-icon": "^3.0.2",
    "ph-utils": "^0.18.0",
    "qrcode-generator-es": "^2.1.2",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "less": "^4.6.4",
    "lightningcss": "^1.32.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitepress": "^1.6.4"
  }
}